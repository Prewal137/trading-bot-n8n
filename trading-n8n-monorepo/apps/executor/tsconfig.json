{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@repo/common": ["../../packages/common/index.ts"],
      "@repo/common/*": ["../../packages/common/*"],
      "@repo/db": ["../../packages/db/index.ts"],
      "@repo/db/client": ["../../packages/db/index.ts"],
      "db/client": ["../../packages/db/index.ts"],
      "@repo/db/*": ["../../packages/db/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
